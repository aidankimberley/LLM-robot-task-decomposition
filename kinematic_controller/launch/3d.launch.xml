<launch>
    <node
        pkg="kinematic_controller"
        exec="kinematic_controller"
        name="kinematic_controller"
        output="screen">

        <param name="urdf_file_name"
            value="$(find-pkg-share kortex_description)/robots/gen3.urdf"/>

        <param name="use_sim_time" value="true"/>
        <param name="with_redundancy" value="true"/>
        <param name="use_6D" value="false"/>

        <param name="joint_state_topic" value="/joint_states"/>
        <param name="end_pose_topic" value="/gen3/feedback/pose"/>
        <param name="end_twist_topic" value="/gen3/feedback/twist"/>
        <param name="reference_twist_topic" value="/gen3/reference/twist"/>
        <param name="joint_velocity_command_topic" value="/gen3/command/joint_velocity"/>
        <param name="reference_homing_velocity_topic" value="/gen3/reference/velocity"/>
    </node>

    <include file="$(find-pkg-share potential_field)/launch/potential_field_task.launch.xml"/>
    <include file="$(find-pkg-share potential_field)/launch/potential_field_joint.launch.xml"/>
</launch>

